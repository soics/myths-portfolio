# Supabase (optional — contact form falls back to mailto:)
# Create your project at https://supabase.com/dashboard/projects
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side Supabase (for api/contact.ts)
# Use the service_role key — NEVER share this with the client
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
